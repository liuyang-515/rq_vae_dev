# Environment variables for RQ-VAE-Recommender

# Data paths
DATA_PATH=./data
CHECKPOINT_PATH=./checkpoints
LOG_PATH=./logs

# Weights & Biases (optional)
WANDB_API_KEY=your_api_key_here
WANDB_PROJECT=rq-vae-recommender
WANDB_ENTITY=your_username

# Hydra settings
HYDRA_FULL_ERROR=1

# PyTorch settings
TORCH_HOME=./.cache/torch